# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.open-next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local content sources
contents/
original/

# generated badge work files
.tmp/
assets/badges/transparent/
public/badges/transparent/
public/badges/master/

# codex local skills/tooling artifacts
.codex/
.agents/skills/
skills-lock.json

# cloudflare local build/deploy cache
.wrangler/
.content-sync/
