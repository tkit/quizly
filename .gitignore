# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# supabase
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# local content sources
contents/
original/

# generated badge work files
.tmp/
assets/badges/transparent/
public/badges/transparent/
public/badges/master/

# content sync legacy sql (do not manage content data in git)
supabase/migrations/*_seed_japanese_grammar_*.sql
supabase/migrations/*_refresh_japanese_grammar_*.sql
