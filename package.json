{
  "name": "quizly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "cf:build": "npm run cf:build:production",
    "cf:build:staging": "node scripts/cloudflare-build-env.mjs build --env staging",
    "cf:build:production": "node scripts/cloudflare-build-env.mjs build",
    "cf:preview": "node scripts/cloudflare-build-env.mjs build --env cloudflare-local && opennextjs-cloudflare preview --env cloudflare-local --port 8788",
    "cf:deploy:production": "node scripts/cloudflare-build-env.mjs build && wrangler deploy --keep-vars",
    "cf:deploy:staging": "node scripts/cloudflare-build-env.mjs build --env staging && wrangler deploy --env staging --keep-vars",
    "cf:deploy:production:built": "wrangler deploy --keep-vars",
    "cf:deploy:staging:built": "wrangler deploy --env staging --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "d1:schema:verify": "rm -f /tmp/quizly-d1-schema.sqlite && sqlite3 /tmp/quizly-d1-schema.sqlite < d1/migrations/0001_initial_schema.sql && sqlite3 /tmp/quizly-d1-schema.sqlite < d1/migrations/0002_cloudflare_state_tables.sql && sqlite3 /tmp/quizly-d1-schema.sqlite < d1/migrations/0003_authjs_tables.sql && sqlite3 /tmp/quizly-d1-schema.sqlite < d1/verify/schema_invariants.sql",
    "d1:migrate:local": "wrangler d1 migrations apply quizly-staging --env cloudflare-local --local",
    "d1:seed:reference:production": "D1_DATABASE_NAME=quizly WRANGLER_ENV= node scripts/d1-seed-reference-data.mjs",
    "d1:seed:reference:staging": "node scripts/d1-seed-reference-data.mjs",
    "d1:validate:reference:production": "D1_DATABASE_NAME=quizly R2_QUESTION_IMAGES_BUCKET=quizly-question-images node scripts/d1-validate-reference-data.mjs",
    "d1:validate:reference:staging": "node scripts/d1-validate-reference-data.mjs",
    "d1:migrate:question-image-paths:production": "D1_DATABASE_NAME=quizly WRANGLER_ENV= node scripts/d1-migrate-question-image-paths.mjs",
    "d1:migrate:question-image-paths:staging": "node scripts/d1-migrate-question-image-paths.mjs",
    "r2:download:content:production": "R2_CONTENT_BUCKET=quizly-content node scripts/r2-download-content-object.mjs",
    "r2:download:content:staging": "R2_CONTENT_BUCKET=quizly-content-staging node scripts/r2-download-content-object.mjs",
    "r2:download:content:dry": "node scripts/r2-download-content-object.mjs --dry-run",
    "r2:upload:question-images:production": "R2_QUESTION_IMAGES_BUCKET=quizly-question-images node scripts/r2-upload-question-images.mjs",
    "r2:upload:question-images:staging": "R2_QUESTION_IMAGES_BUCKET=quizly-question-images-staging node scripts/r2-upload-question-images.mjs",
    "r2:upload:question-images:dry": "node scripts/r2-upload-question-images.mjs --dry-run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@auth/d1-adapter": "^1.11.2",
    "@fontsource/zen-maru-gothic": "^5.2.8",
    "@opennextjs/cloudflare": "^1.19.4",
    "@radix-ui/react-slot": "^1.2.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "lighthouse": "^13.0.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
