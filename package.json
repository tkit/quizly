{
  "name": "quizly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "cf:build": "node scripts/cloudflare-migration-build-env.mjs build",
    "cf:build:staging": "node scripts/cloudflare-migration-build-env.mjs build --env staging",
    "cf:preview": "node scripts/cloudflare-migration-build-env.mjs build --env staging && opennextjs-cloudflare preview --env staging",
    "cf:deploy-built:staging": "wrangler deploy --env staging --keep-vars",
    "cf:deploy:staging": "node scripts/cloudflare-migration-build-env.mjs build --env staging && wrangler deploy --env staging --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migration:new": "npx supabase migration new",
    "db:local:start": "npx supabase start",
    "db:local:stop": "npx supabase stop",
    "db:local:migration:up": "./scripts/supabase-cli.sh local db push --local",
    "db:local:status": "./scripts/supabase-cli.sh local migration list --local",
    "redis:local:start": "docker compose -f docker-compose.redis-local.yml up -d",
    "redis:local:stop": "docker compose -f docker-compose.redis-local.yml down",
    "redis:local:status": "docker compose -f docker-compose.redis-local.yml ps",
    "dev:up": "npm run db:local:start && npm run redis:local:start && npm run db:local:migration:up && npm run dev",
    "dev:down": "npm run redis:local:stop && npm run db:local:stop",
    "db:local:seed:legacy-samples:dry": "node scripts/seed-dev-legacy-samples.mjs --dry-run",
    "db:local:seed:legacy-samples": "node scripts/seed-dev-legacy-samples.mjs",
    "db:prod:migration:up": "ALLOW_SUPABASE_PROD=1 ./scripts/supabase-cli.sh prod db push",
    "db:prod:status": "ALLOW_SUPABASE_PROD=1 ./scripts/supabase-cli.sh prod migration list",
    "db:prod:diff:linked": "ALLOW_SUPABASE_PROD=1 ./scripts/supabase-cli.sh prod db diff --linked --schema public",
    "content:validate": "node scripts/content-sync.mjs validate",
    "content:sync": "node scripts/content-sync.mjs sync",
    "content:sync:dry": "node scripts/content-sync.mjs sync --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/zen-maru-gothic": "^5.2.8",
    "@opennextjs/cloudflare": "^1.19.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "lighthouse": "^13.0.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
